# === Приложение ===
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080
SECRET_KEY=change-me-generate-random-string
CSRF_SECRET_KEY=change-me-generate-random-string

# === PostgreSQL ===
POSTGRES_USER=plombir
POSTGRES_PASSWORD=change-me
POSTGRES_DB=plombirclub
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://plombir:change-me@postgres:5432/plombirclub
DATABASE_URL_SYNC=postgresql://plombir:change-me@postgres:5432/plombirclub

# === Redis / Celery ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# === JWT (HTTP-only cookies) ===
JWT_SECRET_KEY=change-me-generate-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ACCESS_COOKIE_NAME=access_token
JWT_REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=900
FORGOT_PASSWORD_RATE_LIMIT=3
FORGOT_PASSWORD_RATE_WINDOW_SECONDS=3600
CODE_SEND_RATE_LIMIT=1
CODE_SEND_RATE_WINDOW_SECONDS=60
VERIFY_CODE_MAX_ATTEMPTS=5
VERIFICATION_CODE_TTL_SECONDS=300

# === SMTP (Яндекс) ===
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-email@yandex.ru
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=your-email@yandex.ru
SMTP_USE_TLS=true

# === SMS-провайдер ===
SMS_API_URL=https://sms-provider.example/api/send
SMS_API_KEY=change-me
SMS_SENDER_NAME=PlombirClub
